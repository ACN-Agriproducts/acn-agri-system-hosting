{
  "compileOnSave": false,
  "compilerOptions": {
    "ignoreDeprecations": "6.0",
    "baseUrl": "./", // DEPRECATED
    "outDir": "./dist/out-tsc",
    "sourceMap": true,
    "declaration": false,
    "downlevelIteration": true, // DEPRECATED
    "experimentalDecorators": true,
    "module": "esnext",
    "moduleResolution": "node", // DEPRECATED
    "importHelpers": true,
    "target": "ES2022",
    "lib": [
      "es2018",
      "dom"
    ],
    "paths": {
      "@core/*": [
        "src/app/core/*"
      ],
      "@shared/*": [
        "src/app/shared/*"
      ],
      "@layout/*": [
        "src/app/layout/*"
      ],
      "@coreServices/*": [
        "src/app/core/services/*"
      ],
      "@coreModule/*": [
        "src/app/core/module/*"
      ],
      "@model/*": [
        "src/app/core/model/*"
      ],
      "@pages/*": [
        "src/app/pages/*"
      ],
      "@enviroment/*": [
        "src/environments/*"
      ]
    },
    "useDefineForClassFields": false,
    "strict": false,
    // "strictPropertyInitialization": false,
    // "strictNullChecks": false,
  },
  "angularCompilerOptions": {
    "strictInjectionParameters": true,
    "strictTemplates": true
  }
}